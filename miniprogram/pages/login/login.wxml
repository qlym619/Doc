<view class="container">
  <view class="logo">
    <image src="../../images/logo.png" mode="aspectFit"></image>
    <text class="title">医生端登录</text>
  </view>
  
  <view class="form">
    <view class="input-group">
      <text class="label">手机号</text>
      <input 
        class="input" 
        placeholder="请输入手机号" 
        bindinput="bindPhoneInput"
        data-type="phone"
      ></input>
    </view>
    
    <view class="input-group">
      <text class="label">密码</text>
      <input 
        class="input" 
        placeholder="请输入密码" 
        password 
        bindinput="bindPasswordInput"
        data-type="password"
      ></input>
    </view>
    
    <button 
      class="login-btn" 
      bindtap="login"
      disabled="{{!canLogin}}"
    >
      登录
    </button>
  </view>
  
  <view class="footer">
    <text>© 2026 医伴小程序</text>
  </view>
</view>
