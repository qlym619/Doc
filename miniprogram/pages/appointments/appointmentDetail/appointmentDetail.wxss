.container {
  padding: 20rpx;
  min-height: 100vh;
}

.detail-card {
  background-color: white;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.card-header {
  background-color: #1976d2;
  color: white;
  padding: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-badge {
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: normal;
}

.card-content {
  padding: 20rpx;
}

.info-item {
  display: flex;
  margin-bottom: 15rpx;
  align-items: flex-start;
}

.label {
  font-size: 28rpx;
  color: #666;
  width: 150rpx;
  flex-shrink: 0;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn {
  flex: 1;
  padding: 20rpx;
  font-size: 32rpx;
  border-radius: 10rpx;
}
