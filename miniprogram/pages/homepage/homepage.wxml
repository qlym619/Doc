<view class="container">
  <view class="header">
    <view class="user-info">
      <image src="{{doctorInfo.avatarUrl || '../../images/avatar.png'}}" class="avatar"></image>
      <view class="user-details">
        <text class="name">{{doctorInfo.name || '医生'}}</text>
        <text class="department">{{doctorInfo.department || '科室'}}</text>
      </view>
    </view>
    <button class="logout-btn" bindtap="logout">退出</button>
  </view>
  
  <view class="menu">
    <view class="menu-item" bindtap="navigateToPrescriptions">
      <image src="../../images/prescription.png" class="menu-icon"></image>
      <text class="menu-text">处方管理</text>
    </view>
    <view class="menu-item" bindtap="navigateToAppointments">
      <image src="../../images/appointment.png" class="menu-icon"></image>
      <text class="menu-text">预约管理</text>
    </view>
    <view class="menu-item" bindtap="navigateToSettings">
      <image src="../../images/settings.png" class="menu-icon"></image>
      <text class="menu-text">设置</text>
    </view>
  </view>
  
  <view class="stats">
    <view class="stat-item">
      <text class="stat-number">{{todayAppointments}}</text>
      <text class="stat-label">今日预约</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{totalPrescriptions}}</text>
      <text class="stat-label">处方总数</text>
    </view>
  </view>
</view>
