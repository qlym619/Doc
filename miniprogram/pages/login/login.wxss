.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  min-height: 100vh;
}

.logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
  margin-top: 100rpx;
}

.logo image {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}

.logo .title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.form {
  width: 100%;
  max-width: 500rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-group .label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input-group .input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  font-size: 28rpx;
  background-color: #fff;
}

.login-btn {
  width: 100%;
  height: 80rpx;
  background-color: #1976d2;
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 10rpx;
  margin-top: 40rpx;
}

.login-btn[disabled] {
  background-color: #ccc;
}

.footer {
  margin-top: 100rpx;
  font-size: 24rpx;
  color: #999;
}
