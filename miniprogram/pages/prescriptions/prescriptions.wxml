<view class="container">
  <view class="search-bar">
    <input 
      class="search-input" 
      placeholder="搜索患者姓名或处方号" 
      bindinput="bindSearchInput"
    ></input>
    <button class="search-btn" bindtap="search">搜索</button>
  </view>
  
  <view class="prescription-list">
    <view 
      wx:for="{{prescriptions}}" 
      wx:key="{{item._id}}" 
      class="prescription-item"
      bindtap="viewPrescriptionDetail"
      data-id="{{item._id}}"
    >
      <view class="prescription-header">
        <text class="patient-name">{{item.patientName}}</text>
        <text class="prescription-date">{{item.createdAt}}</text>
      </view>
      <view class="prescription-body">
        <text class="prescription-id">处方号: {{item.prescriptionId}}</text>
        <text class="diagnosis">诊断: {{item.diagnosis}}</text>
        <text class="medicines">药品: {{item.medicines.length}}种</text>
      </view>
      <view class="prescription-footer">
        <text class="status">{{item.status}}</text>
        <text class="arrow">→</text>
      </view>
    </view>
  </view>
  
  <button class="add-btn" bindtap="addPrescription">
    + 新增处方
  </button>
</view>
